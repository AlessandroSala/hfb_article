@article{pairing_factors,
title = {An improved pairing interaction for mean field calculations using skyrme potentials*},
journal = {Nuclear Physics A},
volume = {517},
number = {2},
pages = {275-284},
year = {1990},
issn = {0375-9474},
doi = {https://doi.org/10.1016/0375-9474(90)90035-K},
url = {https://www.sciencedirect.com/science/article/pii/037594749090035K},
author = {S.J. Krieger and P. Bonche and H. Flocard and P. Quentin and M.S. Weiss},
abstract = {A zero-range interaction is proposed to calculate nuclear pairing at the Fermi surface. The results of Skyrme calculations using the zero range pairing interaction are compared with those using the constant G model for the pairing, as well as with those of a finite-range calculation. Particular attention is paid to the region of superdeformation and fission.}
}
@article{TERASAKI19951,
title = {Superdeformed rotational bands with density dependent pairing interactions},
journal = {Nuclear Physics A},
volume = {593},
number = {1},
pages = {1-20},
year = {1995},
issn = {0375-9474},
doi = {https://doi.org/10.1016/0375-9474(95)00316-S},
url = {https://www.sciencedirect.com/science/article/pii/037594749500316S},
author = {J. Terasaki and P.-H. Heenen and P. Bonche and J. Dobaczewski and H. Flocard},
abstract = {The cranked Hartree-Fock-Bogoliubov method, applied in a previous study to SD bands of even Hg and Pb isotopes, is extended by including pairing correlations described by a zero-range density-dependent interaction. This more realistic description of the pairing channel modifies the balance between the neutron and proton pairing energies and introduces an orbital variation of the pairing gaps. This results in a retarded alignment, significantly improving the agreement with data in both the A = 150 and 190 mass regions. The behavior expected for SD bands in odd-N or odd-Z nuclei is discussed on the basis of the quasiparticle routhians calculated for the even-even isotopes.}
}
